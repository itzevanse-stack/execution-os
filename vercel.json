{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/",          "destination": "/auth.html"  },
    { "source": "/login",     "destination": "/auth.html"  },
    { "source": "/signup",    "destination": "/auth.html"  },
    { "source": "/dashboard", "destination": "/app.html"   },
    { "source": "/home",      "destination": "/app.html"   },
    { "source": "/app",       "destination": "/app.html"   },
    { "source": "/admin",     "destination": "/admin.html" }
  ],
  "redirects": [
    { "source": "/auth.html",  "destination": "/login",     "permanent": true },
    { "source": "/app.html",   "destination": "/dashboard", "permanent": true },
    { "source": "/admin.html", "destination": "/admin",     "permanent": true }
  ]
}
