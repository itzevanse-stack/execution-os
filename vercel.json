{
  "cleanUrls": true,
  "functions": {
    "api/heygen.js":          { "maxDuration": 60 },
    "api/generate-funnel.js": { "maxDuration": 60 },
    "api/funnel.js":          { "maxDuration": 30 },
    "api/verify-domain.js":   { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/login",     "destination": "/auth.html"  },
    { "source": "/dashboard", "destination": "/app.html"   },
    { "source": "/admin",     "destination": "/admin.html" },
    { "source": "/grow",      "destination": "/grow.html"  }
  ]
}
